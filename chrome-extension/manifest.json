{
  "manifest_version": 3,
  "name": "AfiML — Importador de Afiliados ML",
  "version": "1.0.0",
  "description": "Importe produtos do Mercado Livre direto para o seu site de afiliado em 1 clique.",
  "permissions": ["activeTab", "scripting", "storage", "notifications"],
  "host_permissions": [
    "https://www.mercadolivre.com.br/*",
    "https://produto.mercadolivre.com.br/*",
    "https://*/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": { "32": "icon.png", "128": "icon.png" }
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.mercadolivre.com.br/*",
        "https://produto.mercadolivre.com.br/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": { "32": "icon.png", "128": "icon.png" }
}
