{
  "manifest_version": 3,
  "name": "Marusso Parfum — Importador ML",
  "version": "1.0.0",
  "description": "Adicione perfumes da sua lista de afiliados ML direto no seu site.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "https://www.mercadolivre.com.br/*",
    "https://produto.mercadolivre.com.br/*",
    "https://marusso-parfum.vercel.app/*",
    "http://localhost:5000/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "32": "icon.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.mercadolivre.com.br/*",
        "https://produto.mercadolivre.com.br/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": { "32": "icon.png", "128": "icon.png" }
}
